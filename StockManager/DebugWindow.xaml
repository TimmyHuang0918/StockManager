<Window x:Class="StockManager.DebugWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                Title="股價獲取調試信息" Height="500" Width="700"
                WindowStartupLocation="CenterOwner">
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 標題 -->
                <TextBlock Grid.Row="0" Text="股價獲取日誌" FontSize="16" FontWeight="Bold" 
                                Margin="10" Padding="10" Background="#34495E" Foreground="White"/>

                <!-- 日誌內容 -->
                <ScrollViewer Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="txtLog" IsReadOnly="True" TextWrapping="Wrap" 
                                        FontFamily="Consolas" FontSize="11" BorderThickness="0"
                                        Background="#F8F9FA"/>
                </ScrollViewer>

                <!-- 按鈕 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                        <Button Content="清除日誌" Width="100" Height="30" Margin="0,0,10,0" 
                                        Click="BtnClear_Click" Background="#E74C3C" Foreground="White" 
                                        FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="關閉" Width="100" Height="30" 
                                        Click="BtnClose_Click" Background="#95A5A6" Foreground="White" 
                                        FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
        </Grid>
</Window>
