<Window x:Class="StockManager.UserNameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增使用者" Height="170" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="請輸入使用者名稱" FontWeight="Bold" Foreground="#2C3E50"/>
        <TextBox Grid.Row="1" x:Name="txtUserName" Height="30" Margin="0,8,0,0" VerticalContentAlignment="Center"/>
        <TextBlock Grid.Row="2" Text="可使用中文，系統會自動過濾不合法字元" FontSize="11" Foreground="#607D8B" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="確定" Width="80" Height="30" Margin="0,0,8,0" Click="BtnOk_Click" Background="#27AE60" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Width="80" Height="30" Click="BtnCancel_Click" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
