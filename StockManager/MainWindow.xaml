<Window x:Class="StockManager.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:local="clr-namespace:StockManager"
                xmlns:converters="clr-namespace:StockManager.Converters"
                mc:Ignorable="d"
                Title="股票監控系統 - Stock Manager" Height="700" Width="1200"
                WindowStartupLocation="CenterScreen">
        <Window.Resources>
                <converters:PositiveNegativeConverter x:Key="PositiveNegativeConverter"/>
        </Window.Resources>
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 頂部工具列 -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <TextBlock Text="股票監控系統" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                        <Button x:Name="btnAddStock" Content="+ 新增股票" Width="100" Height="30" Margin="20,0,10,0" Click="BtnAddStock_Click"
                                        Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnRemoveStock" Content="- 移除股票" Width="100" Height="30" Margin="10,0" Click="BtnRemoveStock_Click"
                                        Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnRefresh" Content="🔄 刷新" Width="80" Height="30" Margin="10,0" Click="BtnRefresh_Click"
                                        Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <TextBlock Text="庫存使用者:" Foreground="White" VerticalAlignment="Center" Margin="20,0,8,0"/>
                        <ComboBox x:Name="cboHoldingUser" Width="140" Height="23
                                  " SelectionChanged="CboHoldingUser_SelectionChanged"/>
                        <Button x:Name="btnAddHoldingUser" Content="+新增使用者" Width="100" Height="30" Margin="8,0,0,0"
                                        Click="BtnAddHoldingUser_Click" Background="#546E7A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnDeleteHoldingUser" Content="刪除使用者" Width="96" Height="30" Margin="8,0,0,0"
                                        Click="BtnDeleteHoldingUser_Click" Background="#8D6E63" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                </Border>

                <!-- 主要內容區域 - TabControl -->
                <TabControl Grid.Row="1" x:Name="marketTabControl" Margin="5" SelectionChanged="MarketTabControl_SelectionChanged">
                        <!-- 美股分頁 -->
                        <TabItem Header="美股市場" FontSize="14" FontWeight="Bold">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 美股搜尋列 -->
                                        <Border Grid.Row="0" Margin="10" Background="#ECF0F1" Padding="10">
                                                <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="搜尋:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                                <TextBox x:Name="txtUsSearch" Width="200" Height="25" VerticalContentAlignment="Center" 
                                                                TextChanged="TxtSearch_TextChanged" Tag="US"/>
                                                <TextBlock Text="  股票代號或名稱" VerticalAlignment="Center" Foreground="Gray" Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <TabControl Grid.Row="1" Margin="10">
                                                <TabItem Header="股價列表">
                                                        <DataGrid x:Name="dgUsStocks" AutoGenerateColumns="False"
                                                                IsReadOnly="True" CanUserAddRows="False"
                                                                AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                                HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                                MouseDoubleClick="DataGrid_MouseDoubleClick">
                                                        <DataGrid.Columns>
                                                                <DataGridTextColumn Header="股票代號" Binding="{Binding Ticker}" Width="100" FontWeight="Bold"/>
                                                                <DataGridTextColumn Header="公司名稱" Binding="{Binding Name}" Width="150"/>
                                                                <DataGridTextColumn Header="目前價格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="100"/>
                                                                <DataGridTextColumn Header="前日收盤" Binding="{Binding PreviousClose, StringFormat={}{0:F2}}" Width="100"/>
                                                                <DataGridTemplateColumn Header="漲跌幅 (%)" Width="120">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                        <TextBlock>
                                                                                                <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}{0:F2}%}"/>
                                                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                                                                <Style.Triggers>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Positive">
                                                                                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▲ {0:F2}%}"/>
                                                                                                                        </DataTrigger>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Negative">
                                                                                                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▼ {0:F2}%}"/>
                                                                                                                        </DataTrigger>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent}" Value="{x:Null}">
                                                                                                                                <Setter Property="Foreground" Value="Gray"/>
                                                                                                                                <Setter Property="Text" Value="--"/>
                                                                                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                                                                        </DataTrigger>
                                                                                                                </Style.Triggers>
                                                                                                        </Style>
                                                                                                </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="資料來源" Binding="{Binding Source}" Width="120"/>
                                                                <DataGridTextColumn Header="更新時間" Binding="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}" Width="100"/>
                                                        </DataGrid.Columns>
                                                        </DataGrid>
                                                </TabItem>

                                                <TabItem Header="庫存">
                                                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="10">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                                                <StackPanel MinWidth="500">
                                                                        <TextBlock Text="📒 我的美股庫存" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>

                                                                        <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="300"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                                                        <WrapPanel Margin="0,0,0,8">
                                                                                                <TextBlock Text="代號" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtUsHoldingTicker" Width="100" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <TextBlock Text="股數" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtUsHoldingQty" Width="80" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <TextBlock Text="均價" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtUsHoldingCost" Width="80" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <Button x:Name="btnUsAddHolding" Content="新增" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnUsAddHolding_Click" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnUsUpdateHolding" Content="修改" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnUsUpdateHolding_Click" Background="#F39C12" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnUsRemoveHolding" Content="移除" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnUsRemoveHolding_Click" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnUsResetHoldings" Content="重置" Width="60" Height="26"
                                                                                                                Click="BtnUsResetHoldings_Click" Background="#616161" Foreground="White" BorderThickness="0"/>
                                                                                        </WrapPanel>

                                                                                        <WrapPanel Margin="0,0,0,8">
                                                                                                <TextBlock Text="賣出股數" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtUsSellQty" Width="90" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                                                                                <TextBlock Text="賣出價格" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtUsSellPrice" Width="90" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                                                                                <Button x:Name="btnUsSellHolding" Content="賣出" Width="70" Height="26"
                                                                                                                Click="BtnUsSellHolding_Click" Background="#8E44AD" Foreground="White" BorderThickness="0"/>
                                                                                        </WrapPanel>

                                                                                        <DataGrid x:Name="dgUsHoldings" AutoGenerateColumns="False" IsReadOnly="True" Height="240"
                                                                                                        CanUserAddRows="False" AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                                                                        HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                                                                        SelectionChanged="DgUsHoldings_SelectionChanged">
                                                                                                <DataGrid.Columns>
                                                                                                        <DataGridTextColumn Header="代號" Binding="{Binding Ticker}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="120"/>
                                                                                                        <DataGridTextColumn Header="股數" Binding="{Binding Quantity, StringFormat={}{0:F2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="均價" Binding="{Binding AverageCost, StringFormat={}{0:F2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="現價" Binding="{Binding CurrentPrice, StringFormat={}{0:F2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="市值" Binding="{Binding MarketValue, StringFormat={}{0:F2}}" Width="90"/>
                                                                                                        <DataGridTextColumn Header="總損益"  Binding="{Binding UnrealizedPnL, StringFormat={}{0:F2}}" Width="90"></DataGridTextColumn>
                                                                                                        <DataGridTextColumn Header="損益(%)" Binding="{Binding PnLPercent, StringFormat={}{0:F2}%}" Width="90"/>
                                                                                                </DataGrid.Columns>
                                                                                        </DataGrid>
                                                                                </StackPanel>

                                                                                <Border Grid.Column="1" Background="#F3F5F7" BorderBrush="#DADFE6" BorderThickness="1" CornerRadius="6" Padding="10">
                                                                                        <StackPanel>
                                                                                                <TextBlock Text="損益總覽" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                                                                                <TextBlock x:Name="txtUsTotalPnL" Text="美股未實現：0.00 (0.00%)" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                                                                <TextBlock x:Name="txtUsRealizedPnL" Text="美股已實現：0.00" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                                                        </StackPanel>
                                                                                </Border>
                                                                        </Grid>
                                                                </StackPanel>
                                                        </ScrollViewer>
                                                        </Border>
                                                </TabItem>
                                        </TabControl>
                                </Grid>
                        </TabItem>

                        <!-- 台股分頁 -->
                        <TabItem Header="台股市場" FontSize="14" FontWeight="Bold">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 台股搜尋列 -->
                                        <Border Grid.Row="0" Margin="10" Background="#ECF0F1" Padding="10">
                                                <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="搜尋:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                                <TextBox x:Name="txtTwSearch" Width="200" Height="25" VerticalContentAlignment="Center"
                                                                TextChanged="TxtSearch_TextChanged" Tag="TW"/>
                                                <Button x:Name="btnTwFilter" Content="台股篩選" Width="90" Height="25" Margin="10,0,0,0"
                                                                Click="BtnTwFilter_Click" Background="#607D8B" Foreground="White"
                                                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                                <Button x:Name="btnTwYFinanceCacheUpdate" Content="更新族群快取" Width="100" Height="25" Margin="8,0,0,0"
                                                                Click="BtnTwYFinanceCacheUpdate_Click" Background="#455A64" Foreground="White"
                                                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                                <TextBlock Text="  股票代號或名稱" VerticalAlignment="Center" Foreground="Gray" Margin="10,0,0,0"/>
                                                <ProgressBar x:Name="pbTwSectorCacheUpdate" Width="140" Height="12" Margin="12,0,0,0"
                                                                Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"
                                                                Foreground="#1E88E5" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtTwSectorCachePercent" Text="0%" Margin="6,0,0,0"
                                                                Foreground="#455A64" FontWeight="Bold" Visibility="Collapsed"
                                                                VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtTwSectorCacheEta" Text="預估剩餘 --:--" Margin="8,0,0,0"
                                                                Foreground="#607D8B" Visibility="Collapsed"
                                                                VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Border>

                                        <TabControl Grid.Row="1" Margin="10">
                                                <TabItem Header="股價列表">
                                                        <DataGrid x:Name="dgTwStocks" AutoGenerateColumns="False"
                                                                IsReadOnly="True" CanUserAddRows="False"
                                                                AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                                HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                                MouseDoubleClick="DataGrid_MouseDoubleClick">
                                                        <DataGrid.Columns>
                                                                <DataGridTextColumn Header="股票代號" Binding="{Binding Ticker}" Width="100" FontWeight="Bold"/>
                                                                <DataGridTextColumn Header="公司名稱" Binding="{Binding Name}" Width="150"/>
                                                                <DataGridTextColumn Header="目前價格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="100"/>
                                                                <DataGridTextColumn Header="前日收盤" Binding="{Binding PreviousClose, StringFormat={}{0:F2}}" Width="100"/>
                                                                <DataGridTemplateColumn Header="漲跌幅 (%)" Width="120">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                        <TextBlock>
                                                                                                <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}{0:F2}%}"/>
                                                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                                                                <Style.Triggers>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Positive">
                                                                                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▲ {0:F2}%}"/>
                                                                                                                        </DataTrigger>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Negative">
                                                                                                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                                                                                                <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▼ {0:F2}%}"/>
                                                                                                                        </DataTrigger>
                                                                                                                        <DataTrigger Binding="{Binding ChangePercent}" Value="{x:Null}">
                                                                                                                                <Setter Property="Foreground" Value="Gray"/>
                                                                                                                                <Setter Property="Text" Value="--"/>
                                                                                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                                                                        </DataTrigger>
                                                                                                                </Style.Triggers>
                                                                                                        </Style>
                                                                                                </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="資料來源" Binding="{Binding Source}" Width="120"/>
                                                                <DataGridTextColumn Header="更新時間" Binding="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}" Width="100"/>
                                                        </DataGrid.Columns>
                                                        </DataGrid>
                                                </TabItem>

                                                <TabItem Header="庫存">
                                                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="10">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                                                <StackPanel MinWidth="500">
                                                                        <TextBlock Text="📒 我的台股庫存" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>

                                                                        <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="300"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                                                        <WrapPanel Margin="0,0,0,8">
                                                                                                <TextBlock Text="代號" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtTwHoldingTicker" Width="100" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <TextBlock Text="股數" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtTwHoldingQty" Width="80" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <TextBlock Text="均價" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtTwHoldingCost" Width="80" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                                                                                                <Button x:Name="btnTwAddHolding" Content="新增" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnTwAddHolding_Click" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnTwUpdateHolding" Content="修改" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnTwUpdateHolding_Click" Background="#F39C12" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnTwRemoveHolding" Content="移除" Width="60" Height="26" Margin="0,0,6,0"
                                                                                                                Click="BtnTwRemoveHolding_Click" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                                                                                                <Button x:Name="btnTwResetHoldings" Content="重置" Width="60" Height="26"
                                                                                                                Click="BtnTwResetHoldings_Click" Background="#616161" Foreground="White" BorderThickness="0"/>
                                                                                        </WrapPanel>

                                                                                        <WrapPanel Margin="0,0,0,8">
                                                                                                <TextBlock Text="賣出股數" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtTwSellQty" Width="90" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                                                                                <TextBlock Text="賣出價格" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                <TextBox x:Name="txtTwSellPrice" Width="90" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                                                                                <Button x:Name="btnTwSellHolding" Content="賣出" Width="70" Height="26"
                                                                                                                Click="BtnTwSellHolding_Click" Background="#8E44AD" Foreground="White" BorderThickness="0"/>
                                                                                        </WrapPanel>

                                                                                        <DataGrid x:Name="dgTwHoldings" AutoGenerateColumns="False" IsReadOnly="True" Height="240"
                                                                                                        CanUserAddRows="False" AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                                                                        HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                                                                        SelectionChanged="DgTwHoldings_SelectionChanged">
                                                                                                <DataGrid.Columns>
                                                                                                        <DataGridTextColumn Header="代號" Binding="{Binding Ticker}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="120"/>
                                                                                                        <DataGridTextColumn Header="股數" Binding="{Binding Quantity, StringFormat={}{0:N2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="均價" Binding="{Binding AverageCost, StringFormat={}{0:N2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="現價" Binding="{Binding CurrentPrice, StringFormat={}{0:N2}}" Width="80"/>
                                                                                                        <DataGridTextColumn Header="市值" Binding="{Binding MarketValue, StringFormat={}{0:N2}}" Width="90"/>
                                                                                                        <DataGridTextColumn Header="總損益" Binding="{Binding UnrealizedPnL, StringFormat={}{0:N2}}" Width="90"/>
                                                                                                        <DataGridTextColumn Header="損益(%)" Binding="{Binding PnLPercent, StringFormat={}{0:N2}%}" Width="90"/>
                                                                                                </DataGrid.Columns>
                                                                                        </DataGrid>
                                                                                </StackPanel>

                                                                                <Border Grid.Column="1" Background="#F3F5F7" BorderBrush="#DADFE6" BorderThickness="1" CornerRadius="6" Padding="10">
                                                                                        <StackPanel>
                                                                                                <TextBlock Text="損益總覽" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                                                                                <TextBlock x:Name="txtTwTotalPnL" Text="台股未實現：0.00 (0.00%)" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                                                                <TextBlock x:Name="txtTwRealizedPnL" Text="台股已實現：0.00" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                                                        </StackPanel>
                                                                                </Border>
                                                                        </Grid>
                                                                </StackPanel>
                                                        </ScrollViewer>
                                                        </Border>
                                                </TabItem>
                                        </TabControl>
                                </Grid>
                        </TabItem>
                </TabControl>

                <!-- 最新新聞 -->
                <Border Grid.Row="2" Margin="8,0,8,6" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="📰 最新新聞" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <TextBlock x:Name="txtMaxImpactStock" DockPanel.Dock="Right" Foreground="#C62828" FontWeight="Bold"/>
                                </DockPanel>

                                <DataGrid x:Name="dgNewsImpact" AutoGenerateColumns="False" IsReadOnly="True" Height="130"
                                                  CanUserAddRows="False" HeadersVisibility="Column" FontSize="11"
                                                  AlternatingRowBackground="#F8F9FA">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="時間" Binding="{Binding Time}" Width="110"/>
                                                <DataGridTextColumn Header="最新新聞標題" Binding="{Binding Headline}" Width="*"/>
                                                <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="120"/>
                                                <DataGridTextColumn Header="重要性分數" Binding="{Binding ImportanceScore}" Width="90"/>
                                                <DataGridTextColumn Header="影響程度" Binding="{Binding ImportanceLevel}" Width="80"/>
                                        </DataGrid.Columns>
                                </DataGrid>
                        </StackPanel>
                </Border>

                <!-- 進度條 -->
                <ProgressBar Grid.Row="3" x:Name="progressBar" Height="8" Minimum="0" Maximum="100" 
                                        Foreground="#3498DB" BorderThickness="0"/>

                <!-- 底部狀態列 -->
                <StatusBar Grid.Row="4" Background="#34495E" Height="30">
                        <StatusBarItem>
                                <TextBlock x:Name="statusText" Text="準備就緒" Foreground="White" FontSize="12"/>
                        </StatusBarItem>
                </StatusBar>
        </Grid>
</Window>
