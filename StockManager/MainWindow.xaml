<Window x:Class="StockManager.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:local="clr-namespace:StockManager"
                xmlns:converters="clr-namespace:StockManager.Converters"
                mc:Ignorable="d"
                Title="股票監控系統 - Stock Manager" Height="700" Width="1200"
                WindowStartupLocation="CenterScreen">
        <Window.Resources>
                <converters:PositiveNegativeConverter x:Key="PositiveNegativeConverter"/>
        </Window.Resources>
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 頂部工具列 -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <TextBlock Text="股票監控系統" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                        <Button x:Name="btnAddStock" Content="+ 新增股票" Width="100" Height="30" Margin="20,0,10,0" Click="BtnAddStock_Click"
                                        Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnRemoveStock" Content="- 移除股票" Width="100" Height="30" Margin="10,0" Click="BtnRemoveStock_Click"
                                        Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnRefresh" Content="🔄 刷新" Width="80" Height="30" Margin="10,0" Click="BtnRefresh_Click"
                                        Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnDebug" Content="🐛 調試" Width="80" Height="30" Margin="10,0" Click="BtnDebug_Click"
                                        Background="#9B59B6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="btnTestAPI" Content="🌐 測試API" Width="100" Height="30" Margin="10,0" Click="BtnTestAPI_Click"
                                        Background="#16A085" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                </Border>

                <!-- 主要內容區域 - TabControl -->
                <TabControl Grid.Row="1" x:Name="marketTabControl" Margin="5" SelectionChanged="MarketTabControl_SelectionChanged">
                        <!-- 美股分頁 -->
                        <TabItem Header="美股市場" FontSize="14" FontWeight="Bold">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 美股搜尋列 -->
                                        <Border Grid.Row="0" Margin="10" Background="#ECF0F1" Padding="10">
                                                <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="搜尋:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                                <TextBox x:Name="txtUsSearch" Width="200" Height="25" VerticalContentAlignment="Center" 
                                                                TextChanged="TxtSearch_TextChanged" Tag="US"/>
                                                <TextBlock Text="  股票代號或名稱" VerticalAlignment="Center" Foreground="Gray" Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <!-- 美股列表 -->
                                        <DataGrid Grid.Row="1" x:Name="dgUsStocks" AutoGenerateColumns="False" 
                                                        IsReadOnly="True" Margin="10" CanUserAddRows="False"
                                                        AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                        HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                        MouseDoubleClick="DataGrid_MouseDoubleClick">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="股票代號" Binding="{Binding Ticker}" Width="100" FontWeight="Bold"/>
                                                        <DataGridTextColumn Header="公司名稱" Binding="{Binding Name}" Width="150"/>
                                                        <DataGridTextColumn Header="目前價格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="100"/>
                                                        <DataGridTextColumn Header="前日收盤" Binding="{Binding PreviousClose, StringFormat={}{0:F2}}" Width="100"/>
                                                        <DataGridTemplateColumn Header="漲跌幅 (%)" Width="120">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                                <TextBlock>
                                                                                        <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}{0:F2}%}"/>
                                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                                        <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Positive">
                                                                                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▲ {0:F2}%}"/>
                                                                                                                </DataTrigger>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Negative">
                                                                                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▼ {0:F2}%}"/>
                                                                                                                </DataTrigger>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent}" Value="{x:Null}">
                                                                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                                                                        <Setter Property="Text" Value="--"/>
                                                                                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                                                                                </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                </Style>
                                                                                        </TextBlock.Style>
                                                                                </TextBlock>
                                                                        </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="資料來源" Binding="{Binding Source}" Width="120"/>
                                                        <DataGridTextColumn Header="更新時間" Binding="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}" Width="100"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </Grid>
                        </TabItem>

                        <!-- 台股分頁 -->
                        <TabItem Header="台股市場" FontSize="14" FontWeight="Bold">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 台股搜尋列 -->
                                        <Border Grid.Row="0" Margin="10" Background="#ECF0F1" Padding="10">
                                                <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="搜尋:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                                <TextBox x:Name="txtTwSearch" Width="200" Height="25" VerticalContentAlignment="Center"
                                                                TextChanged="TxtSearch_TextChanged" Tag="TW"/>
                                                <Button x:Name="btnTwFilter" Content="台股篩選" Width="90" Height="25" Margin="10,0,0,0"
                                                                Click="BtnTwFilter_Click" Background="#607D8B" Foreground="White"
                                                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                                <TextBlock Text="  股票代號或名稱" VerticalAlignment="Center" Foreground="Gray" Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <!-- 台股列表 -->
                                        <DataGrid Grid.Row="1" x:Name="dgTwStocks" AutoGenerateColumns="False" 
                                                        IsReadOnly="True" Margin="10" CanUserAddRows="False"
                                                        AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                                                        HeadersVisibility="Column" FontSize="12" SelectionMode="Single"
                                                        MouseDoubleClick="DataGrid_MouseDoubleClick">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="股票代號" Binding="{Binding Ticker}" Width="100" FontWeight="Bold"/>
                                                        <DataGridTextColumn Header="公司名稱" Binding="{Binding Name}" Width="150"/>
                                                        <DataGridTextColumn Header="目前價格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="100"/>
                                                        <DataGridTextColumn Header="前日收盤" Binding="{Binding PreviousClose, StringFormat={}{0:F2}}" Width="100"/>
                                                        <DataGridTemplateColumn Header="漲跌幅 (%)" Width="120">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                                <TextBlock>
                                                                                        <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}{0:F2}%}"/>
                                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                                        <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Positive">
                                                                                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▲ {0:F2}%}"/>
                                                                                                                </DataTrigger>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Negative">
                                                                                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                                                                                        <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▼ {0:F2}%}"/>
                                                                                                                </DataTrigger>
                                                                                                                <DataTrigger Binding="{Binding ChangePercent}" Value="{x:Null}">
                                                                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                                                                        <Setter Property="Text" Value="--"/>
                                                                                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                                                                                </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                </Style>
                                                                                        </TextBlock.Style>
                                                                                </TextBlock>
                                                                        </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="資料來源" Binding="{Binding Source}" Width="120"/>
                                                        <DataGridTextColumn Header="更新時間" Binding="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}" Width="100"/>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </Grid>
                        </TabItem>
                </TabControl>

                <!-- 最新新聞 -->
                <Border Grid.Row="2" Margin="8,0,8,6" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="📰 最新新聞" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <TextBlock x:Name="txtMaxImpactStock" DockPanel.Dock="Right" Foreground="#C62828" FontWeight="Bold"/>
                                </DockPanel>

                                <DataGrid x:Name="dgNewsImpact" AutoGenerateColumns="False" IsReadOnly="True" Height="130"
                                                  CanUserAddRows="False" HeadersVisibility="Column" FontSize="11"
                                                  AlternatingRowBackground="#F8F9FA">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="時間" Binding="{Binding Time}" Width="110"/>
                                                <DataGridTextColumn Header="最新新聞標題" Binding="{Binding Headline}" Width="*"/>
                                                <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="120"/>
                                                <DataGridTextColumn Header="重要性分數" Binding="{Binding ImportanceScore}" Width="90"/>
                                                <DataGridTextColumn Header="影響程度" Binding="{Binding ImportanceLevel}" Width="80"/>
                                        </DataGrid.Columns>
                                </DataGrid>
                        </StackPanel>
                </Border>

                <!-- 進度條 -->
                <ProgressBar Grid.Row="3" x:Name="progressBar" Height="8" Minimum="0" Maximum="100" 
                                        Foreground="#3498DB" BorderThickness="0"/>

                <!-- 底部狀態列 -->
                <StatusBar Grid.Row="4" Background="#34495E" Height="30">
                        <StatusBarItem>
                                <TextBlock x:Name="statusText" Text="準備就緒" Foreground="White" FontSize="12"/>
                        </StatusBarItem>
                </StatusBar>
        </Grid>
</Window>
