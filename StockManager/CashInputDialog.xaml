<Window x:Class="StockManager.CashInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Initial Cash"
        Height="180"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Please enter initial cash" FontWeight="Bold" Foreground="#2C3E50"/>
        <TextBox Grid.Row="1" x:Name="txtCashAmount" Height="30" Margin="0,8,0,0" VerticalContentAlignment="Center"/>
        <TextBlock Grid.Row="2" Text="Amount must be greater than or equal to 0" FontSize="11" Foreground="#607D8B" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,8,0" Click="BtnOk_Click" Background="#27AE60" Foreground="White" BorderThickness="0"/>
            <Button Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
