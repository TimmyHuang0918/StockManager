<Window x:Class="StockManager.TwStockFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:StockManager.Converters"
        Title="台股篩選" Height="560" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Window.Resources>
        <converters:PositiveNegativeConverter x:Key="PositiveNegativeConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DADFE6" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="台股條件篩選" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                <TextBlock x:Name="txtDataStatus" Text="資料來源：載入中..." FontSize="12" Foreground="#607D8B" Margin="0,0,0,10"/>

                <WrapPanel>
                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="最低價格" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtMinPrice" Width="110" Height="28" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="最小漲跌幅 (%)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtMinChange" Width="120" Height="28" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="最大漲跌幅 (%)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtMaxChange" Width="120" Height="28" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,18,16,8" VerticalAlignment="Center">
                        <CheckBox x:Name="chkOnlyRising" Content="只看上漲" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Margin="0,14,0,8">
                        <Button x:Name="btnApplyFilter" Content="套用篩選" Width="92" Height="30"
                                Click="BtnApplyFilter_Click" Background="#1976D2" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Margin="10,14,0,8">
                        <Button x:Name="btnSectorOverview" Content="族群漲跌總覽" Width="110" Height="30"
                                Click="BtnSectorOverview_Click" Background="#455A64" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#DADFE6" BorderThickness="1" CornerRadius="6" Padding="8">
            <DataGrid x:Name="dgFilteredTwStocks" AutoGenerateColumns="False" IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="股票代號" Binding="{Binding Ticker}" Width="110"/>
                    <DataGridTextColumn Header="公司名稱" Binding="{Binding Name}" Width="180"/>
                    <DataGridTextColumn Header="目前價格" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="110"/>
                    <DataGridTemplateColumn Header="漲跌幅 (%)" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}{0:F2}}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Positive">
                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                    <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▲ {0:F2}}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChangePercent, Converter={StaticResource PositiveNegativeConverter}}" Value="Negative">
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                    <Setter Property="Text" Value="{Binding ChangePercent, StringFormat={}▼ {0:F2}}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChangePercent}" Value="{x:Null}">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Setter Property="Text" Value="--"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="買賣分數" Binding="{Binding TradingScore}" Width="90"/>
                    <DataGridTextColumn Header="建議" Binding="{Binding TradingSuggestion}" Width="130"/>
                    <DataGridTextColumn Header="前日收盤" Binding="{Binding PreviousClose, StringFormat={}{0:F2}}" Width="110"/>
                    <DataGridTextColumn Header="更新時間" Binding="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
