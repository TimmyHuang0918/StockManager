<Window x:Class="StockManager.TrendAnalysisWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                Title="股票趨勢分析" Height="750" Width="1100"
                WindowStartupLocation="CenterOwner" Background="#F5F5F5">
        <Window.Resources>
                <!-- 樣式定義 -->
                <Style x:Key="StatCardStyle" TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Padding" Value="15"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Effect">
                                <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="TabButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#666"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="Margin" Value="2,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <Style x:Key="PeriodComboBoxStyle" TargetType="ComboBox">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#263238"/>
                        <Setter Property="BorderBrush" Value="#90CAF9"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Height" Value="32"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#42A5F5"/>
                                        <Setter Property="Background" Value="#F5FAFF"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#1E88E5"/>
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <Style x:Key="PeriodComboBoxItemStyle" TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>
        </Window.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 標題列 -->
                <Border Grid.Row="0" Background="#1976D2" Padding="20">
                        <Grid>
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="txtTitle" Text="股票趨勢分析" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="txtSubtitle" Text="載入中..." FontSize="13" Foreground="#E3F2FD" Margin="0,5,0,0"/>
                                        <ProgressBar x:Name="pbLoading" Height="6" Width="280" Margin="0,8,0,0" Visibility="Collapsed" Minimum="0" Maximum="100" Value="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="股票：" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cboStockSwitcher" Width="180" Height="23" IsEditable="False" Margin="0,0,14,0"
                                                          DisplayMemberPath="DisplayName" SelectedValuePath="Ticker"
                                                          Style="{StaticResource PeriodComboBoxStyle}"
                                                          SelectionChanged="CboStockSwitcher_SelectionChanged"
                                                          KeyDown="CboStockSwitcher_KeyDown"/>
                                        <TextBlock Text="時間週期：" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox x:Name="cboPeriod" Width="130" Height="23" Style="{StaticResource PeriodComboBoxStyle}" SelectionChanged="CboPeriod_SelectionChanged">
                                                <ComboBoxItem Content="5分K" Tag="5m" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="1個月" Tag="1mo" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="3個月" Tag="3mo" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="6個月" Tag="6mo" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="1年" Tag="1y" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="2年" Tag="2y" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                        </ComboBox>
                                        <Button x:Name="btnRealtimeKLine" Content="即時K線：關閉" Width="118" Height="30" Margin="10,0,0,0"
                                                        Background="#546E7A" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                                                        Click="BtnRealtimeKLine_Click"/>
                                        <TextBlock x:Name="txtIntradayBarsLabel" Text="K棒數：" Foreground="White" VerticalAlignment="Center" Margin="10,0,6,0" Visibility="Collapsed"/>
                                        <ComboBox x:Name="cboIntradayBars" Width="86" Height="23" Visibility="Collapsed"
                                                          Style="{StaticResource PeriodComboBoxStyle}" SelectionChanged="CboIntradayBars_SelectionChanged">
                                                <ComboBoxItem Content="30根" Tag="30" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="60根" Tag="60" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="120根" Tag="120" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                                <ComboBoxItem Content="240根" Tag="240" Style="{StaticResource PeriodComboBoxItemStyle}"/>
                                        </ComboBox>
                                </StackPanel>
                        </Grid>
                </Border>

                <!-- 統計卡片區 -->
                <Grid Grid.Row="1" Margin="15,15,15,10">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                        <TextBlock Text="當前價格" FontSize="11" Foreground="#999" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtCurrentPrice" Text="--" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                                </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                        <TextBlock Text="今日漲跌" FontSize="11" Foreground="#999" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtChange" Text="--" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                        <TextBlock Text="最高價" FontSize="11" Foreground="#999" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtHigh" Text="--" FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                        <TextBlock Text="最低價" FontSize="11" Foreground="#999" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtLow" Text="--" FontSize="20" FontWeight="Bold" Foreground="#F44336"/>
                                </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                        <TextBlock Text="成交量" FontSize="11" Foreground="#999" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtVolume" Text="--" FontSize="18" FontWeight="Bold" Foreground="#FF9800"/>
                                </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Style="{StaticResource StatCardStyle}" Margin="5,10,5,0" Background="#E8F5E9">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📌 目前交易建議：" FontSize="13" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="txtCurrentRecommendation" Text="分析中..." FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20" TextWrapping="Wrap"/>
                                </StackPanel>
                        </Border>
                </Grid>

                <!-- 分頁標籤 -->
                <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnTabChart" Content="📊 價格走勢" Style="{StaticResource TabButtonStyle}" Click="BtnTabChart_Click" Background="#E3F2FD"/>
                                <Button x:Name="btnTabTechnical" Content="📈 技術指標" Style="{StaticResource TabButtonStyle}" Click="BtnTabTechnical_Click"/>
                                <Button x:Name="btnTabAnalysis" Content="💡 AI 分析" Style="{StaticResource TabButtonStyle}" Click="BtnTabAnalysis_Click"/>
                        </StackPanel>
                </Border>

                <!-- 主要內容區域 -->
                <Border Grid.Row="3" Margin="15" Background="White" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                                <!-- 價格走勢分頁 -->
                                <ScrollViewer x:Name="chartTab" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="20">
                                                <TextBlock Text="📊 價格走勢圖" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                                                <!-- K 線主圖 -->
                                                <TextBlock Text="K 線價格走勢" FontSize="13" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,6"/>
                                                <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10" MinHeight="280">
                                                        <Canvas x:Name="chartCanvas" Background="White" SizeChanged="ChartCanvas_SizeChanged" MouseMove="ChartCanvas_MouseMove" MouseLeave="ChartCanvas_MouseLeave"/>
                                                </Border>

                                                <!-- 成交量子圖 -->
                                                <TextBlock Text="成交量" FontSize="13" FontWeight="SemiBold" Foreground="#666" Margin="0,15,0,6"/>
                                                <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10" Height="140">
                                                        <Canvas x:Name="volumeCanvas" Background="White" SizeChanged="IndicatorCanvas_SizeChanged"/>
                                                </Border>

                                                <!-- MACD 子圖 -->
                                                <TextBlock Text="MACD" FontSize="13" FontWeight="SemiBold" Foreground="#666" Margin="0,15,0,6"/>
                                                <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10" Height="140">
                                                        <Canvas x:Name="macdCanvas" Background="White" SizeChanged="IndicatorCanvas_SizeChanged"/>
                                                </Border>

                                                <!-- RSI 子圖 -->
                                                <TextBlock Text="RSI" FontSize="13" FontWeight="SemiBold" Foreground="#666" Margin="0,15,0,6"/>
                                                <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10" Height="140">
                                                        <Canvas x:Name="rsiCanvas" Background="White" SizeChanged="IndicatorCanvas_SizeChanged"/>
                                                </Border></StackPanel>
                                </ScrollViewer>

                                <!-- 技術指標分頁 -->
                                <ScrollViewer x:Name="technicalTab" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                        <StackPanel Margin="20">
                                                <TextBlock Text="📈 技術指標分析" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                                                <!-- 移動平均線 (MA) -->
                                                <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                                        <StackPanel>
                                                                <TextBlock Text="📉 移動平均線 (MA)" FontSize="15" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                                <TextBlock Text="MA5 (5日均線)" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtMA5" Text="--" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                                                <TextBlock Text="MA20 (20日均線)" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtMA20" Text="--" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2">
                                                                                <TextBlock Text="MA60 (60日均線)" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtMA60" Text="--" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                                                                        </StackPanel>
                                                                </Grid>
                                                                <TextBlock x:Name="txtMAAnalysis" TextWrapping="Wrap" FontSize="12" Margin="0,15,0,0" Foreground="#424242"/>
                                                        </StackPanel>
                                                </Border>

                                                <!-- RSI 指標 -->
                                                <Border Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="2" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                                        <StackPanel>
                                                                <TextBlock Text="📊 相對強弱指標 (RSI)" FontSize="15" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,10"/>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="RSI(14)：" FontSize="13" Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                                <TextBlock x:Name="txtRSI" Text="--" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                                <ProgressBar x:Name="pbRSI" Width="200" Height="20" Margin="15,0,0,0" Maximum="100" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                </Grid>
                                                                <TextBlock x:Name="txtRSIAnalysis" TextWrapping="Wrap" FontSize="12" Margin="0,15,0,0" Foreground="#424242"/>
                                                        </StackPanel>
                                                </Border>

                                                <!-- MACD 指標 -->
                                                <Border Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="2" CornerRadius="8" Padding="20">
                                                        <StackPanel>
                                                                <TextBlock Text="📈 MACD 指標" FontSize="15" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,10"/>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                                <TextBlock Text="MACD" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtMACD" Text="--" FontSize="16" FontWeight="Bold"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                                                <TextBlock Text="Signal" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtSignal" Text="--" FontSize="16" FontWeight="Bold"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2">
                                                                                <TextBlock Text="Histogram" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                                                                <TextBlock x:Name="txtHistogram" Text="--" FontSize="16" FontWeight="Bold"/>
                                                                        </StackPanel>
                                                                </Grid>
                                                                <TextBlock x:Name="txtMACDAnalysis" TextWrapping="Wrap" FontSize="12" Margin="0,15,0,0" Foreground="#424242"/>
                                                        </StackPanel>
                                                </Border>
                                        </StackPanel>
                                </ScrollViewer>

                                <!-- AI 分析分頁 -->
                                <ScrollViewer x:Name="analysisTab" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                        <StackPanel Margin="20">
                                                <TextBlock Text="💡 AI 智能分析" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                                                <!-- 最新重大新聞 -->
                                                <Border Background="#F5F5F5" BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                                        <StackPanel>
                                                                <TextBlock Text="📰 最新重大新聞" FontSize="15" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,10"/>
                                                                <DataGrid x:Name="dgMajorNews" AutoGenerateColumns="False" IsReadOnly="True" Height="170"
                                                                          HeadersVisibility="Column" CanUserAddRows="False" FontSize="11"
                                                                          AlternatingRowBackground="#FAFAFA" GridLinesVisibility="Horizontal">
                                                                        <DataGrid.Columns>
                                                                                <DataGridTextColumn Header="時間" Binding="{Binding Time}" Width="90"/>
                                                                                <DataGridTextColumn Header="重大新聞標題" Binding="{Binding Title}" Width="*"/>
                                                                                <DataGridTextColumn Header="影響程度" Binding="{Binding ImpactLevel}" Width="80"/>
                                                                        </DataGrid.Columns>
                                                                </DataGrid>
                                                        </StackPanel>
                                                </Border>

                                                <!-- 綜合評分 -->
                                                <Border BorderBrush="#9C27B0" BorderThickness="2" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                                                        <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#F3E5F5" Offset="0"/>
                                                                        <GradientStop Color="#E1BEE7" Offset="1"/>
                                                                </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel>
                                                                <TextBlock Text="綜合評分" FontSize="16" FontWeight="Bold" Foreground="#6A1B9A" Margin="0,0,0,15"/>
                                                                <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock x:Name="txtScore" Text="--" FontSize="48" FontWeight="Bold" Grid.Column="0" Margin="0,0,20,0"/>
                                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                                <ProgressBar x:Name="pbScore" Height="30" Maximum="100" Foreground="#9C27B0"/>
                                                                                <TextBlock x:Name="txtScoreLevel" Text="評估中..." FontSize="14" FontWeight="Bold" Margin="0,10,0,0" Foreground="#6A1B9A"/>
                                                                        </StackPanel>
                                                                </Grid>
                                                        </StackPanel>
                                                </Border>

                                                <!-- 財報分析 -->
                                                <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                                        <StackPanel>
                                                                <TextBlock Text="📑 財報數據分析（yfinance）" FontSize="15" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                                                                <TextBlock x:Name="txtFundamentalAnalysis" Text="載入財報數據中..." TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#2F3B45"/>
                                                        </StackPanel>
                                                </Border>

                                                <!-- 買賣建議 -->
                                                <Border x:Name="suggestionBorder" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                                        <StackPanel>
                                                                <TextBlock x:Name="txtSuggestionTitle" Text="💰 投資建議" FontSize="15" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                                                                <TextBlock x:Name="txtSuggestion" TextWrapping="Wrap" FontSize="13" LineHeight="22" Foreground="#424242"/>
                                                        </StackPanel>
                                                </Border>

                                                <!-- 風險提示 -->
                                                <Border Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="2" CornerRadius="8" Padding="20">
                                                        <StackPanel>
                                                                <TextBlock Text="⚠️ 風險提示" FontSize="15" FontWeight="Bold" Foreground="#C62828" Margin="0,0,0,10"/>
                                                                <TextBlock x:Name="txtRiskWarning" TextWrapping="Wrap" FontSize="12" LineHeight="20" Foreground="#424242"/>
                                                        </StackPanel>
                                                </Border>
                                        </StackPanel>
                                </ScrollViewer>
                        </Grid>
                </Border>

                <!-- 底部按鈕 -->
                <Border Grid.Row="4" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🔄 刷新數據" Width="110" Height="38" Margin="0,0,10,0"
                                                Click="BtnRefresh_Click" Background="#2196F3" Foreground="White" 
                                                FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="13"/>
                                <Button Content="關閉" Width="110" Height="38"
                                                Click="BtnClose_Click" Background="#9E9E9E" Foreground="White" 
                                                FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="13"/>
                        </StackPanel>
                </Border>
        </Grid>
</Window>



