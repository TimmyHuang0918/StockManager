<Application x:Class="StockManager.App"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:StockManager"
                        StartupUri="MainWindow.xaml">
        <Application.Resources>
                <Style x:Key="SlimScrollThumbStyle" TargetType="Thumb">
                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Thumb">
                                                <Border Background="#7FAEC8" CornerRadius="4"/>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="TransparentRepeatButtonStyle" TargetType="RepeatButton">
                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <ControlTemplate x:Key="VerticalSlimScrollBarTemplate" TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="8" Margin="0,2,2,2">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource TransparentRepeatButtonStyle}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource SlimScrollThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource TransparentRepeatButtonStyle}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Grid>
                </ControlTemplate>

                <ControlTemplate x:Key="HorizontalSlimScrollBarTemplate" TargetType="ScrollBar">
                        <Grid Background="Transparent" Height="8" Margin="2,0,2,2">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource TransparentRepeatButtonStyle}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource SlimScrollThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource TransparentRepeatButtonStyle}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Grid>
                </ControlTemplate>

                <Style TargetType="ScrollBar">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Width" Value="8"/>
                        <Setter Property="Height" Value="8"/>
                        <Style.Triggers>
                                <Trigger Property="Orientation" Value="Vertical">
                                        <Setter Property="Width" Value="8"/>
                                        <Setter Property="Template" Value="{StaticResource VerticalSlimScrollBarTemplate}"/>
                                </Trigger>
                                <Trigger Property="Orientation" Value="Horizontal">
                                        <Setter Property="Height" Value="8"/>
                                        <Setter Property="Template" Value="{StaticResource HorizontalSlimScrollBarTemplate}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseCaptureWithin" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>
        </Application.Resources>
</Application>
